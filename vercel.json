{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/*.js", "use": "@vercel/node" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "crons": [
    { "path": "/api/send-wa", "schedule": "0 2 * * *" },
    { "path": "/api/send-wa", "schedule": "0 7 * * *" },
    { "path": "/api/send-wa", "schedule": "0 11 * * *" },
    { "path": "/api/send-wa", "schedule": "0 14 * * *" }
  ]
}
